# ── Database ──────────────────────────────────────────────────────────────────
# Railway: usa la variable DATABASE_URL que Railway inyecta automáticamente
# Local: debe coincidir con docker-compose.yml (puerto 5433)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DB_NAME"

# ── Auth.js ───────────────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
AUTH_SECRET=""
NEXTAUTH_URL="https://tu-dominio.railway.app"

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://tu-dominio.railway.app"

# ── Admin Setup ───────────────────────────────────────────────────────────────
# Credenciales del primer administrador (usado por /api/auth/register-admin)
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
# Clave secreta para habilitar el endpoint de registro del admin inicial
ADMIN_SETUP_KEY=""

# ── Email (Resend) ────────────────────────────────────────────────────────────
# Obtén tu API key en: https://resend.com
RESEND_API_KEY="re_..."

# ── RFID ──────────────────────────────────────────────────────────────────────
# Clave para autenticar los lectores RFID externos en /api/rfid/read
RFID_API_KEY=""

# ── Cloudflare R2 (Object Storage para Imágenes) ──────────────────────────────
# Obtén tus credenciales en: https://dash.cloudflare.com/profile/api-tokens
# 1. Ve a tu cuenta Cloudflare > R2
# 2. Crea un bucket (ej: "shock-images")
# 3. Genera "API Token" con permisos: Object Read/Write
# 4. Copia: Account ID, Access Key ID, Secret Access Key
R2_ACCOUNT_ID="tu_account_id"
R2_ACCESS_KEY_ID="tu_access_key"
R2_SECRET_ACCESS_KEY="tu_secret_key"
R2_BUCKET_NAME="shock-images"
R2_ENDPOINT="https://tu_account_id.r2.cloudflarestorage.com"
R2_PUBLIC_URL="https://tu-custom-domain.com"
R2_REGION="auto"
R2_PRODUCTS_PREFIX="products"
# NOTA: las imagenes 360 de ubicaciones NO usan R2; se sirven desde public/images/ubicaciones

# ── Redis (Rate Limiting) ─────────────────────────────────────────────────────
# Railway: usa la variable REDIS_URL que Railway inyecta automáticamente
# Si no se define, el rate limiter usa memoria (solo válido para 1 instancia)
REDIS_URL="redis://default:PASSWORD@HOST:PORT"
